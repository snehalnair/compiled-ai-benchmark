# Copy this file to `.env` (in this benchmark/ folder OR the project root) and fill in.
# The harness auto-loads it. Real shell environment variables take precedence over .env.

ANTHROPIC_API_KEY=sk-ant-...

# Open-weight models via an OpenAI-compatible endpoint. We use OpenRouter; any
# OpenAI-compatible provider works (Together / Fireworks / DeepInfra / Groq ...).
# OPENROUTER_API_KEY, OPEN_API_KEY, or OPENAI_API_KEY are all accepted as the key.
OPENROUTER_API_KEY=
OPEN_BASE_URL=https://openrouter.ai/api/v1

# Cheap model 1 (primary). Pin prices to the model's real $/1M at run time.
OPEN_MODEL=qwen/qwen-2.5-7b-instruct
OPEN_INPUT_PRICE_PER_M=0.04
OPEN_OUTPUT_PRICE_PER_M=0.10

# Cheap model 2 (disagreement-gate router in sweep.py; ensemble member in harden.py).
OPEN_MODEL_2=meta-llama/llama-3.1-8b-instruct
OPEN2_INPUT_PRICE_PER_M=0.02
OPEN2_OUTPUT_PRICE_PER_M=0.03

# Cheap model 3 (third ensemble member in harden.py).
OPEN_MODEL_3=mistralai/mistral-small-24b-instruct-2501
OPEN3_INPUT_PRICE_PER_M=0.05
OPEN3_OUTPUT_PRICE_PER_M=0.08

# optional override
# FRONTIER_MODEL=claude-opus-4-8
